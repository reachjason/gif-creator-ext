{
  "manifest_version": 3,
  "name": "Window GIF Creator",
  "version": "1.0.0",
  "description": "Record a region of your screen, tab, or any window and export it as a GIF.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Window GIF Creator"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/gif.worker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
